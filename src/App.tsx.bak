import { useState, useEffect, useRef } from "react";
import { getCurrentWindow } from "@tauri-apps/api/window";
import { askAI, AIProvider } from "./services/ai";

interface TauriWindow {
  setOpacity(value: number): Promise<void>;
  show(): Promise<void>;
  setAlwaysOnTop(enabled: boolean): Promise<void>;
  setIgnoreCursorEvents(ignore: boolean): Promise<void>;
}

interface Message {
  role: "ai" | "user";
  text: string;
}

function App() {
  const [opacity, setOpacity] = useState(0.92);
  const [input, setInput] = useState("");
  const [messages, setMessages] = useState<Message[]>([{ role: "ai", text: "Overlay Ready." }]);
  const [loading, setLoading] = useState(false);
  const [provider, setProvider] = useState<AIProvider>("gemini");
  const [clickThrough, setClickThrough] = useState(false);
  const bottomRef = useRef<HTMLDivElement>(null);
  const appWindow = getCurrentWindow() as unknown as TauriWindow;

  useEffect(() => {
    const init = async () => {
      await new Promise(r => setTimeout(r, 150));
      try {
        await appWindow.show();
        await appWindow.setAlwaysOnTop(true);
      } catch (e) {
        console.error("Init failed", e);
      }
    };
    init();
  }, [appWindow]);

  // Auto-scroll to bottom on new messages
  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  const toggleClickThrough = async () => {
    const next = !clickThrough;
    setClickThrough(next);
    await appWindow.setIgnoreCursorEvents(next).catch(console.error);
  };

  const handleSend = async () => {
    if (!input.trim() || loading) return;
    setMessages(prev => [...prev, { role: "user", text: input }]);
    setInput("");
    setLoading(true);

    // Add empty AI message to stream into
    setMessages(prev => [...prev, { role: "ai", text: "" }]);

    try {
      await askAI(provider, input, (chunk) => {
        setMessages(prev => {
          const updated = [...prev];
          updated[updated.length - 1] = {
            role: "ai",
            text: updated[updated.length - 1].text + chunk,
          };
          return updated;
        });
      });
    } catch (err) {
      setMessages(prev => {
        const updated = [...prev];
        updated[updated.length - 1] = { role: "ai", text: "Error: Service unreachable." };
        return updated;
      });
    } finally {
      setLoading(false);
    }
  };

  const updateOpacity = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const val = parseFloat(e.target.value);
    setOpacity(val);
    await appWindow.setOpacity(val).catch(console.error);
  };

  return (
    <main style={{ opacity }} className="flex flex-col h-screen bg-slate-900 text-white border border-slate-700 rounded-xl overflow-hidden shadow-2xl">
      {/* Header */}
      <div data-tauri-drag-region className="flex justify-between items-center p-3 bg-slate-800 cursor-move border-b border-slate-700">
        <select
          value={provider}
          onChange={(e) => setProvider(e.target.value as AIProvider)}
          className="bg-slate-700 text-xs px-2 py-1 rounded border border-slate-600 outline-none text-white"
        >
          <option value="gemini">Gemini</option>
          <option value="openai">GPT-4o</option>
          <option value="claude">Claude</option>
        </select>
        <div className="flex items-center gap-2">
          {/* Click-through toggle */}
          <button
            onClick={toggleClickThrough}
            title={clickThrough ? "Click-through ON (overlay inactive)" : "Click-through OFF"}
            className={`text-xs px-2 py-1 rounded border transition-colors ${
              clickThrough
                ? "bg-yellow-500 border-yellow-400 text-black"
                : "bg-slate-700 border-slate-600 text-slate-300"
            }`}
          >
            {clickThrough ? "👁 Pass" : "🖱 Active"}
          </button>
          <input
            type="range" min="0.1" max="1" step="0.01" value={opacity}
            onChange={updateOpacity}
            className="w-16 h-1 accent-blue-500 cursor-pointer"
          />
        </div>
      </div>

      {/* Messages */}
      <div className="flex-grow overflow-y-auto p-4 space-y-3" style={{ scrollbarWidth: "thin", scrollbarColor: "#334155 transparent" }}>
        {messages.map((msg, i) => (
          <div
            key={i}
            className={`p-2 rounded-lg text-xs max-w-xs leading-relaxed whitespace-pre-wrap ${
              msg.role === "ai"
                ? "bg-slate-800 text-blue-100"
                : "bg-blue-600 text-white ml-auto"
            }`}
          >
            {msg.text}
            {loading && i === messages.length - 1 && msg.role === "ai" && (
              <span className="animate-pulse">▋</span>
            )}
          </div>
        ))}
        <div ref={bottomRef} />
      </div>

      {/* Input */}
      <div className="p-3 bg-slate-800 border-t border-slate-700">
        <input
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyDown={(e) => e.key === "Enter" && !e.shiftKey && handleSend()}
          disabled={loading}
          className="w-full p-2 bg-slate-700 rounded text-xs focus:outline-none border border-transparent focus:border-blue-500 disabled:opacity-50"
          placeholder={loading ? "Waiting..." : `Ask ${provider}...`}
        />
      </div>
    </main>
  );
}

export default App;

